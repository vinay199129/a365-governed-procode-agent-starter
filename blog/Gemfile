source "https://rubygems.org"

# GitHub Pages gem keeps Jekyll + plugins pinned to the versions that
# GitHub Pages uses in production. See:
# https://pages.github.com/versions/
gem "github-pages", group: :jekyll_plugins

# Theme used by _config.yml. github-pages bundles minima already, but we list
# it explicitly so `bundle exec jekyll serve` works locally too.
gem "minima"

# Windows + JRuby compatibility shims (recommended by the Jekyll docs).
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswin]

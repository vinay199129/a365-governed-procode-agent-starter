{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "checkJs": true,
    "noEmit": true,
    "allowJs": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": ["**/*.js"],
  "exclude": ["**/*-manifest.js"]
}
